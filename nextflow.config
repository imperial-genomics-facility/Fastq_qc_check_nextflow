// Global default params, used in configs
params {
    input = null
    params.outdir = 'results'
}

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'

profiles {
    docker {
        docker.enabled         = true
        conda.enabled          = false
        singularity.enabled    = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        conda.enabled          = false
        docker.enabled         = false
        podman.enabled         = false
        shifter.enabled        = false
        charliecloud.enabled   = false
        apptainer.enabled      = false
    }
    test   { 
        includeConfig 'conf/test.config'
    }
}

// Set to your registry if you have a mirror of containers
docker.registry = 'quay.io'

manifest {
    name            = 'Fastq_qc_check_nextflow'
    author          = """Jessica Tam, Hamza Halane, Avik Datta"""
    homePage        = 'https://github.com/imperial-genomics-facility/Fastq_qc_check_nextflow'
    description     = """Nextflow pipeline for quality control of fastq files."""
    mainScript      = 'main.nf'
    nextflowVersion = null
    version         = '0.1.0'
    doi             = null
}